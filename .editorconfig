root = true

[*]
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
charset = utf-8

[*.rs]
indent_style = space
indent_size = 4

[*.{yaml,yml,toml,json}]
indent_style = space
indent_size = 2

# .sh.yaml files contain both YAML (space-indented) and embedded shell scripts
# (which may have tabs in heredoc bodies). Block scalars (|) for stdout/stderr
# have blank indented lines that look like trailing whitespace.
[*.sh.yaml]
indent_style = unset
trim_trailing_whitespace = unset
end_of_line = unset

[*.md]
indent_style = space
indent_size = 2
trim_trailing_whitespace = false

[*Dockerfile]
indent_style = tab
